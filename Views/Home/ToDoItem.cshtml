<div class="card shadow-sm border-0 my-4">
    <div class="card-header bg-primary text-white">
        <h3 class="mb-0">@Model.Title</h3>
    </div>
    <div class="card-body">
        <p class="lead">@(!string.IsNullOrEmpty(Model.Description) ? Model.Description : "<em>No description available.</em>")</p>

        <dl class="row mb-3">
            <dt class="col-sm-4 text-muted">Due Date</dt>
            <dd class="col-sm-8">@Model.DueDate.ToString("MMMM dd, yyyy")</dd>

            <dt class="col-sm-4 text-muted">Status</dt>
            <dd class="col-sm-8">
                @if (Model.IsCompleted)
                {
                    <span class="badge bg-success">Completed</span>
                }
                else if (Model.DueDate.Date < DateTime.Today)
                {
                    <span class="badge bg-danger">Overdue</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">Pending</span>
                }
            </dd>
        </dl>

    </div>
    <div class="card-footer d-flex justify-content-between align-items-center">
        <a asp-action="Index" class="btn btn-outline-secondary">← Back to List</a>

        <div class="d-flex gap-2">
            <form asp-action="ToggleComplete" asp-route-id="@Model.Id" method="post">
                <button type="submit" class="btn @(Model.IsCompleted ? "btn-outline-warning" : "btn-success")">
                    @(Model.IsCompleted ? "Mark as Incomplete" : "Mark as Completed")
                </button>
            </form>

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                  onsubmit="return confirm('Delete this ToDo item?');">
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
        </div>
    </div>
</div>