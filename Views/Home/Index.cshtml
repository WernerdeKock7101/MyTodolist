@model IEnumerable<MyToDoList.Models.ToDoItem>

<h2 class="mb-4">ToDo List</h2>

<div class="list-group">
    @foreach (var item in Model)
    {
        // Determine CSS class based on status
        var cssClass = "list-group-item list-group-item-action";
        if (item.IsCompleted)
        {
            cssClass += " list-group-item-success"; // green
        }
        else if (item.DueDate < DateTime.Now)
        {
            cssClass += " list-group-item-danger"; // red
        }
        // else default (no extra class)

        <a asp-controller="Home" asp-action="ToDoItem" asp-route-id="@item.Id" class="@cssClass">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-1">@item.Title</h5>
                <small>Due: @item.DueDate.ToShortDateString()</small>
            </div>
        </a>
    }
</div>

<a asp-action="AddToDo" class="btn btn-primary mt-4">Add New ToDo</a>



